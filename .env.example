# GST Portal credentials
GST_APPLICANT_ID=
GST_PASSWORD=

# Telegram bot configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Poll interval in seconds (900 = 15 minutes)
POLL_SECONDS=900

# Local state file to avoid duplicate alerts
STATE_FILE=state.json

# Optional: send one startup message when still unpublished
NOTIFY_ON_UNPUBLISHED=false
